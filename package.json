{
  "name": "paputclient",
  "productName": "Paput Client",
  "version": "1.0.15",
  "description": "Paput Client — modpack manager privado para Minecraft (premium) con sincronización automática",
  "author": "Renso Abraham",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && electron-builder",
    "build:dir": "tsc --noEmit && vite build && electron-builder --dir",
    "release": "tsc --noEmit && vite build && electron-builder --publish always",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "publish": "tsx scripts/publish.ts",
    "serve-modpack": "tsx scripts/serve-modpack.ts"
  },
  "build": {
    "appId": "one.unicornio.paputclient",
    "productName": "Paput Client",
    "copyright": "Copyright © 2026 Renso Abraham",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "RensoAbraham",
        "repo": "MinecraftClientCode",
        "releaseType": "release"
      }
    ],
    "electronLanguages": [
      "es"
    ],
    "compression": "maximum",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Paput Client"
    }
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "electron-updater": "^6.8.9",
    "eml-lib": "^2.3.7",
    "extract-zip": "^2.0.1",
    "skinview3d": "^3.4.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8",
    "ffmpeg-static": "^5.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
